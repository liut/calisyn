# Glob API URL
VITE_API_PATH=/api

VITE_API_PROXY_TO=http://127.0.0.1:3002/

# Whether long replies are supported, which may result in higher API fees
VITE_OPEN_LONG_REPLY=false

# When you want to use PWA
VITE_PWA_ENABLE=false

# Base public path
VITE_BASE_PATH=

# localStorage token name for whole site API authentication (default: token)
VITE_SITE_TOKEN_KEY=token

# Header name for whole site API authentication (default: token)
VITE_SITE_HEADER_KEY=token

VITE_SHOW_CONFIG=true

# App logo filename (default: logo.png)
# 支持本地文件（logo.png）或外部 URL（https://cdn.example.com/logo.png）
VITE_APP_LOGO=logo.png
