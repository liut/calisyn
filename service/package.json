{
  "name": "calisyn-service",
  "version": "1.0.0",
  "private": false,
  "description": "Calisyn backend service built with Express, supporting OpenAI API and multiple models",
  "author": "ChenZhaoYu <chenzhaoyu1994@gmail.com>, liut <liutao@liut.cc>",
  "keywords": [
    "calisyn",
    "chatgpt",
    "chatbot",
    "express"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "esno ./src/index.ts",
    "dev": "esno watch ./src/index.ts",
    "prod": "node ./build/index.mjs",
    "build": "pnpm clean && tsup",
    "clean": "rimraf build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "common:cleanup": "rimraf node_modules && rimraf pnpm-lock.yaml"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.6",
    "debug": "^4.3.4",
    "dotenv": "^16.0.3",
    "esno": "^4.7.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "simple-oauth2": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.35.3",
    "@types/express": "^4.17.17",
    "@types/node": "^18.14.6",
    "eslint": "^8.35.0",
    "rimraf": "^4.3.0",
    "tsup": "^6.6.3",
    "typescript": "^4.9.5"
  }
}
